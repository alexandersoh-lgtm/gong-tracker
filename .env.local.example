# Jira credentials for the Launch Command Center (/command-center).
# Copy to .env.local for local dev. In production, set these in Vercel:
# Project → Settings → Environment Variables (then redeploy).
#
# The API token is created at:
#   https://id.atlassian.com/manage-profile/security/api-tokens
# These values are read ONLY server-side and are never exposed to the browser.

JIRA_BASE_URL=https://zillowgroup.atlassian.net
JIRA_EMAIL=alexandersohn@zillowgroup.com
JIRA_API_TOKEN=
